rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Only authenticated users can write (no public sign-up exists, so only manually added users can log in)
    function isAdmin() {
      return request.auth != null;
    }

    // Exams collection
    match /exams/{examId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories collection
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Results collection
    match /results/{resultId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admit Cards collection
    match /admitCards/{cardId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Blog Posts collection
    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Answer Keys collection
    match /answerKeys/{keyId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Stats collection for view count
    match /stats/{document} {
      allow read: if true;
      allow write: if true;
    }
    
    // Default rule: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
